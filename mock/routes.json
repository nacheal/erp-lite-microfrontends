{
  "/api/auth/login": {
    "POST": {
      "code": 200,
      "message": "登录成功",
      "data": {
        "token": "mock-jwt-token-" + Date.now(),
        "user": {
          "id": "1",
          "name": "Admin User",
          "role": "admin",
          "permissions": ["user:view", "user:edit", "user:delete", "product:view", "product:edit", "product:delete", "order:view", "order:export"]
        }
      }
    }
  },
  "/api/auth/logout": {
    "POST": {
      "code": 200,
      "message": "登出成功",
      "data": null
    }
  },
  "/api/auth/user": {
    "GET": {
      "code": 200,
      "message": "获取成功",
      "data": {
        "id": "1",
        "name": "Admin User",
        "role": "admin",
        "permissions": ["user:view", "user:edit", "user:delete", "product:view", "product:edit", "product:delete", "order:view", "order:export"]
      }
    }
  },
  "/api/micro-apps/config": {
    "GET": {
      "code": 200,
      "message": "获取成功",
      "data": [
        {
          "name": "app-user",
          "entry": "//localhost:3001",
          "activeRule": "/user",
          "enabled": true,
          "version": "1.0.0"
        },
        {
          "name": "app-product",
          "entry": "//localhost:3002",
          "activeRule": "/product",
          "enabled": true,
          "version": "1.0.0"
        },
        {
          "name": "app-order",
          "entry": "//localhost:3003",
          "activeRule": "/order",
          "enabled": true,
          "version": "1.0.0"
        },
        {
          "name": "app-dashboard",
          "entry": "//localhost:3004",
          "activeRule": "/dashboard",
          "enabled": true,
          "version": "1.0.0"
        }
      ]
    }
  }
}
