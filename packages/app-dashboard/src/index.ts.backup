import type { MicroAppLifeCycles, MicroAppProps } from '@erp-lite/types';

// 数据看板样式 - 必须在所有函数之前定义
const DASHBOARD_STYLES = `
.app-dashboard {
  padding: 20px;
  background: #f5f5f5;
